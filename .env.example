# Database (Neon or Supabase). Both are required — see README on why.
DATABASE_URL=""
DIRECT_URL=""

# Optional: raises NCBI's PubMed rate limit from 3 req/sec to 10 req/sec.
# Free — https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=""

# Required. Contact info Wikipedia's API policy asks you to identify with.
WIKIPEDIA_USER_AGENT="HerbHealCompass/1.0 (https://your-domain.example; you@example.com)"

# Required. Long random string — protects /api/sync/daily from being
# triggered by anyone who finds the URL. Generate with: openssl rand -hex 32
CRON_SECRET=""

NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Plant.id API key (free trial: https://plant.id)
# Sign up at https://plant.id, copy your API key here
PLANT_ID_API_KEY=""

# Firebase web config
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_MEASUREMENT_ID=""

# Gemini API for chatbot assistance
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash-latest"

# Google Sheets published CSV URL for live market prices
# Create a Google Sheet with columns: scientific_name,common_name,price_per_kg,currency,buyer_location
# Publish as CSV: File → Share → Publish to web → choose CSV format
GOOGLE_SHEET_CSV_URL=""
