# Database (Prisma SQLite or Supabase PostgreSQL)
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# NCBI & Wikipedia API User-Agent
NCBI_API_KEY=""
WIKIPEDIA_USER_AGENT="HerbHealCompass/1.0 (https://your-domain.example; you@example.com)"

# Required. Long random string protecting daily sync endpoint
CRON_SECRET="dev-secret-change-in-production"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Plant.id API key (v3)
PLANT_ID_API_KEY="your-plantid-api-key"

# Identification strategy ("custom-first" tries ml/infer.py first, falls back to Plant.id v3)
IDENTIFY_STRATEGY="custom-first"
CUSTOM_MODEL_URL=""

# Supabase Web & Server Config (Replaces Firebase)
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Gemini API for chatbot assistance
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.5-flash"

# Google Sheets published CSV URL for live market prices
GOOGLE_SHEET_CSV_URL=""
