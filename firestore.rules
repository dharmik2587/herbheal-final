rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // scan_events / market_views: analytics logs written by our own server-
    // side API routes using the client SDK. Client-side writes are allowed
    // (the app has no auth flow yet) but capped to prevent junk/abuse — no
    // arbitrary field, no massive payloads. Reads are server-only via the
    // Admin SDK equivalent (not exposed to the public client).
    match /scan_events/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['source', 'createdAt'])
                    && request.resource.data.size() < 20;
      allow read, update, delete: if false;
    }

    match /market_views/{viewId} {
      allow create: if request.resource.data.size() < 10;
      allow read, update, delete: if false;
    }

    match /chat_messages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['role', 'content'])
                    && request.resource.data.content is string
                    && request.resource.data.content.size() < 5000;
      allow read, update, delete: if false;
    }

    // Deny everything else by default — never leave a project on the
    // default "allow if true" test-mode rules past the first 30 days.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
